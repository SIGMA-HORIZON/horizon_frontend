  "dynamicRoutes": [
    {
      "page": "/dashboard/mes-vms/[vmid]",
      "regex": "^/dashboard/mes\\-vms/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPvmid": "nxtPvmid"
      },
      "namedRegex": "^/dashboard/mes\\-vms/(?<nxtPvmid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
